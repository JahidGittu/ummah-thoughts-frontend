  "methodology": {
    "badge": "Living Document",
    "lastUpdated": "Last Updated",
    "title": "Our Methodology",
    "subtitle": "A living document explaining how Ummah Thoughts approaches Islamic knowledge, handles disagreements, and maintains intellectual integrity.",
    "classification": {
      "title": "How Rulings Are Classified",
      "description": "Every ruling and position is classified based on the level of scholarly agreement, allowing readers to understand the strength and certainty of each view.",
      "ijma": { "level": "Ijma' (Consensus)", "description": "Matters agreed upon by all major scholars across schools of thought." },
      "jumhur": { "level": "Jumhur (Majority)", "description": "Position held by the majority of scholars, with known dissent." },
      "ikhtilaf": { "level": "Ikhtilaf (Disagreement)", "description": "Legitimate scholarly difference with multiple valid positions." },
      "shadh": { "level": "Shadh (Isolated)", "description": "Minority opinion not widely accepted, presented for academic completeness." }
    },
    "disagreement": {
      "title": "How Disagreements Are Handled",
      "description": "Scholarly disagreement (ikhtilaf) is a mercy. We present it with adab (etiquette) and intellectual honesty.",
      "step1": { "title": "Present All Positions", "description": "Each valid scholarly position is documented with its evidence and methodology." },
      "step2": { "title": "Identify Cause of Difference", "description": "Whether linguistic, textual, methodological, or contextual." },
      "step3": { "title": "Respect Legitimate Difference", "description": "No position is dismissed if held by recognized scholars with valid evidence." },
      "step4": { "title": "Avoid Forcing Consensus", "description": "We do not artificially reconcile genuine differences." }
    },
    "changelog": {
      "title": "Methodology Change Log",
      "entry1": "Added explicit guidance on handling minority opinions in historical contexts.",
      "entry2": "Initial methodology document published."
    },
    "redLines": {
      "title": "What We Refuse To Do",
      "items": [
        "Promoting takfir (excommunication) of Muslims",
        "Inciting violence or rebellion",
        "Political party formation or endorsement",
        "Sectarian attacks or prejudice",
        "Content that weaponizes Islamic knowledge",
        "Simplifying complex rulings for political agendas"
      ]
    },
    "neutral": {
      "title": "Where We Stay Neutral",
      "description": "These matters are presented without institutional bias:",
      "items": [
        "Specific political systems (democracy, monarchy, etc.)",
        "Modern nation-state boundaries",
        "Intra-Sunni school preferences (Hanafi, Maliki, etc.)",
        "Permissibility of specific modern technologies",
        "Economic systems beyond clear prohibitions"
      ]
    },
    "accountability": {
      "title": "Publicly Accountable",
      "description": "This methodology is public for accountability. We welcome scholarly critique and correction."
    }
  },
